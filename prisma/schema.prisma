// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ─────────────────────────────────────────────────────────────────────

enum TransactionStatus {
  pending
  failed // ← fixed from "failde"
  success
}

enum TransferStatus {
  processing
  success
  failed
}

enum PaymentStatus { 
  CREATED 
  PENDING 
  VERIFYING 
  SUCCESS 
  FAILED 
  EXPIRED 
  REFUNDED 
}

enum role {
  user
  vendor
  admin
}

enum VendorType {
  restaurant
  grocery
  drinks
  retail
}

enum VendorStatus {
  pending
  approved
  rejected
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum OrderStatus {
  pending
  confirmed
  preparing
  outForDelivery
  delivered
  completed
  pendingFundRelease
  cancelled
  appealed
}

enum EscrowStatus {
  held
  released
  appealed
  refunded
  noEscrow
  cancelled
}

enum CoinPurchaseSource { 
  apple_iap 
  google_play 
  wallet_ngn 
  opay_ngn 
} // add opay_ngn for web purchases

enum CoinPurchaseStatus {
   PENDING 
   SUCCESS 
   FAILED 
   REFUNDED
}




// ── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  firebaseUid          String    @unique
  name                 String
  email                String    @unique
  phone                String    @default("") 
  role                 role      @default(user)
  active               Boolean   @default(true)
  pin                  String?   // hashed wallet PIN for transaction auth
  notificationsEnabled Boolean   @default(true)
  notificationToken    String?
  referralCode         String?   @unique
  referredBy           String?
  transferUid          String    @unique
  deletedAt            DateTime? // soft delete
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // ─── Global / Region ───────────────────────────────────────────────────────
  country           String?          // ISO 3166-1 alpha-2, e.g. "NG", "US"
  currency          String?          // ISO 4217, e.g. "NGN", "USD"
  timezone          String?          // IANA, e.g. "Africa/Lagos"

  // ─── Transaction PIN (REPLACES SharedPreferences storage) ─────────────────
  transactionPinHash  String?        // bcrypt hash — NEVER store plaintext
  
  // ─── Social Auth ──────────────────────────────────────────────────────────
  // Optional — track which provider was used for sign-up analytics
  authProvider      String?          // "email" | "google" | "apple"

   // ─── Transaction PIN reset ────────────────────────────────────────────────
  pinResetOtpHash   String?    // SHA-256 hash of OTP
  pinResetOtpExpiry DateTime?

  // ─── Password reset (unauthenticated flow) ────────────────────────────────
  passwordResetOtpHash   String?
  passwordResetOtpExpiry DateTime?

  kyc            Kyc?
  badges         Badges?
  coins            UserCoins?
  creatorStats     CreatorStats?

  hideFromLeaderboardCreators Boolean @default(false) // opt out of public Spotlight boards
  hideFromLeaderboardSupporters Boolean @default(false)

  virtualAccount VirtualAccount[]
  wallet         Wallet?
  orders         Order[]
  userProfile    UserProfile?
  transactions   Transaction[]
  payments Payment[]
  notifications  Notification[]

  vendor         Vendor[]

  sentTransfers     Transfer[] @relation("TransferSender")
  receivedTransfers Transfer[] @relation("TransferReceiver")
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]
  savedPosts        SavedPost[]
  postViewTrackers  PostViewTracker[] @relation("PostViews")
  followers         Follow[] @relation("Following")
  following         Follow[] @relation("Follower")
  searchHistory SearchHistory[]
  
  sentGifts        GiftTransaction[] @relation("GiftSender")
  receivedGifts    GiftTransaction[] @relation("GiftReceiver")
  coinConversions  CoinConversion[]  @relation("CoinConversions")
  coinPurchases    CoinPurchase[] @relation("CoinPurchases")
  coinBoosts       CoinBoost[]    @relation("CoinBoosts")

  @@index([firebaseUid, createdAt])
  @@index([email])
   @@index([name])
  @@index([transferUid])
  @@index([phone])
}

model UserProfile {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  userName               String?  @unique
  bio                    String   @default("")
  location               String?
  website                String?
  businessEmail          String?
  avatarUrl              String   @default("")
  coverPhotoUrl          String   @default("")
  badges                 Badges?

  followersCount         Int      @default(0)
  followingCount         Int      @default(0)

  postCount              Int      @default(0)

  isPrivate              Boolean  @default(false)
  isVerified             Boolean  @default(false)

  totalEarnings          Float    @default(0)

  allowFollowersToMessage Boolean  @default(false)
  weeklyEarned           Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userName])                          
  @@index([followersCount])                    
  @@index([isVerified, followersCount])       
}

model Badges {
  id         String   @id @default(uuid())
  profileId     String @unique
  userId        String @unique
  kycBlue   Boolean  @default(false)
  premiumPaid  Boolean  @default(false)
  business   Boolean  @default(false)
  creatorEarnings Boolean @default(false)

  userPofile UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VirtualAccount {
  id            String    @id @default(uuid())
  userId        String
  bankName      String
  accountNumber String
  status        String    @default("active")
  expiresAt     DateTime? // some DVAs expire
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fiat Fiat?
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Fiat {
  id               String   @id @default(uuid())
  walletId         String   @unique
  currency         String   @default("NGN") // ISO 4217 — future-proofs multi-currency
  availableBalance Float    @default(0)
  lockedBalance    Float    @default(0)
  rewardBalance    Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String
  type            String // "credit" | "debit" | "utility" | "wallet" | etc.
  amount          Float
  transactionRef  String?
  humanRef        String?
  clientRequestId String?           @unique
  metaData        Json?
  orderId         String?           @unique
  status          TransactionStatus @default(pending)
  message         String?
  transferId      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transfer Transfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([userId, createdAt])
  @@index([transactionRef])
  @@index([humanRef])
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  amount          Float
  currency        String        @default("NGN")
  provider        String        // "wallet" | "opay"
  status          PaymentStatus @default(CREATED)
  providerRef     String?
  providerMeta    Json?
  entityType      String        // "marketplace_order" | "utility" | "dine_in_order"
  entityId        String
  clientRequestId String?       @unique
  webhookVerified Boolean       @default(false)
  webhookPayload  Json?
  webhookReceivedAt DateTime?
  returnUrl       String?
  expiresAt       DateTime?
  attempts        PaymentAttempt[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user User @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([status])
  @@index([providerRef])
  @@index([entityId])
}

model PaymentAttempt {
  id          String   @id @default(uuid())
  paymentId   String
  provider    String
  status      String
  providerRef String?
  response    Json?
  createdAt   DateTime @default(now())
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  @@index([paymentId])
}

model MerchantTrustProfile {
  id       String @id @default(uuid())
  vendorId String @unique
  level    Int    @default(0)            // 0 unverified · 1 identity · 2 trusted · 3 business
  identityDocumentUrl String?
  identityVerified    Boolean @default(false)
  faceVerified        Boolean @default(false)
  phoneVerified       Boolean @default(false)
  cacVerified         Boolean  @default(false)   // Vendor.cacCertificateUrl already stores the doc
  verificationFeePaid Boolean  @default(false)
  adminApproved       Boolean  @default(false)
  adminReviewNote     String?
  adminReviewedAt     DateTime?
  adminReviewedBy     String?
  settlementDelayHours Int   @default(48)         // 48 | 24 | 0
  dailyWithdrawalLimit Float @default(50000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model TrustLevelUpgradeRequest {
  id        String   @id @default(uuid())
  vendorId  String
  toLevel   Int
  status    String   @default("pending") // pending | approved | rejected
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([vendorId])
  @@index([status])
}

model RestaurantTable {
  id          String   @id @default(uuid())
  vendorId    String
  branchId    String
  tableNumber String
  capacity    Int      @default(4)
  isActive    Boolean  @default(true)
  qrCodeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  @@unique([branchId, tableNumber])
  @@index([vendorId])
  @@index([branchId])
}

model DailyOrderCounter {
  id       String @id @default(uuid())
  branchId String
  date     String // YYYY-MM-DD
  counter  Int    @default(0)
  @@unique([branchId, date])
  @@index([branchId])
}

model Transfer {
  id                String         @id @default(uuid())
  senderId          String?
  receiverId        String?
  amount            Float
  status            TransferStatus @default(processing)
  clientRequestId   String?        @unique
  humanRef          String?
  mode              String         @default("wallet")
  paystackRecipient String?
  metaData          Json?
  providerResponse  Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sender   User? @relation("TransferSender", fields: [senderId], references: [id], onDelete: SetNull)
  receiver User? @relation("TransferReceiver", fields: [receiverId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Post {
  id                 String    @id @default(uuid())
  userId             String
  userName           String    @default("Anonymous")
  userHandle         String?   
  topBadge           String?
  userAvatar         String?
  title              String?
  text               String    @default("")
  images             String[]    @default([])
  hashtags           String[]
  likeCount          Int       @default(0)
  commentCount       Int       @default(0)

  // ADD:
  giftCount     Int       @default(0)  // Total gifts received
  coinTotal     Int       @default(0)  // Total coins from gifts
  
  viewCount          Int       @default(0)
  isBoosted          Boolean   @default(false)
  boostExpiresAt     DateTime?
  algorithmScore     Float     @default(10)
  isRepost           Boolean   @default(false)
  originalPostId     String?
  originalUserName   String?
  originalUserHandle String?
  score              Float     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes    PostLike[]
  comments PostComment[]
  savedBy       SavedPost[]
  viewTrackers  PostViewTracker[]
  reposts        Repost[] @relation("OriginalPost")

  @@index([userId, createdAt])
  @@index([text])                             // Full-text search index (PostgreSQL)
  @@index([algorithmScore, createdAt])
  @@index([isBoosted, createdAt])
  @@index([createdAt])              
}

model PostLike {
  postId String
  userId String // Prisma User.id (authenticated user)

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model PostComment {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  userName   String   @default("Anonymous")
  userAvatar String?
  text       String
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model SavedPost {
  userId  String
  postId  String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, savedAt])
}

model Repost {
  id             String   @id @default(uuid())
  repostPostId   String   @unique
  originalPostId String
  reposterId     String
  createdAt      DateTime @default(now())
  originalPost   Post     @relation("OriginalPost", fields: [originalPostId], references: [id], onDelete: Cascade)

  @@index([originalPostId])
  @@index([reposterId])
}

model PostViewTracker {
  postId       String
  viewerId     String
  lastViewedAt DateTime
  viewCount    Int      @default(1)

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewer User @relation("PostViews", fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([postId, viewerId])
}

model Follow {
  followerId String
  followingId String
  createdAt DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

enum SuggestionKind {
  user
  hashtag
  query
}

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String
  kind        SuggestionKind
  label       String
  subLabel    String?
  avatarUrl   String?
  refUserId   String?  // if kind == "user"
  searchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])   // upsert key
  @@index([userId, searchedAt])
}

model Kyc {
  id        String   @id @default(uuid())
  status    String   @default("unverified") // unverified | pending | verified | rejected
  userId    String   @unique
  document  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("general") // "transaction" | "promo" | "system" | "general"
  read      Boolean  @default(false)
  metaData  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Vendor {
  id                   String     @id @default(uuid())

  ownerId              String // Postgres User.id of the vendor owner (FK -> User.id below)

  ownerFirebaseUid     String // LEGACY/UNUSED: kept for back-compat; ownerId is the real link. Drop in a future migration.

  vendorType           VendorType
  name                 String
  description          String
  logo                 String     @default("")
  coverPhoto           String     @default("")
  email                String     @default("")
  phone                String     @default("")
  cac                  String     @default("")
  cacCertificateUrl    String?    @default("")
  rating               Float      @default(0)
  totalCompletedOrders Int        @default(0)
  completionRate       Float      @default(100)
  podCommissionOwed    Float @default(0)
  verified             Boolean    @default(false)
  verificationStatus   VerificationStatus @default(unverified)
  // existing...
  allowsPayOnDelivery  Boolean    @default(false)

  status    VendorStatus @default(pending)
  rejectionMessage      String?
  isVisible Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  branches Branch[]
  orders   Order[]
  reviews  Review[]
  

  trustProfile     MerchantTrustProfile?
  tables           RestaurantTable[]
  fulfillmentTypes String[]              @default(["delivery"])

  user User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([status, isVisible, rating, id])
}

model Branch {
  id       String @id @default(uuid())
  vendorId String

  isMainBranch Boolean @default(false)

  managerId String?

  managerUid String? // Firebase UID of person managing this branch

  state                 String
  lga                   String
  area                  String
  street                String
  estimatedDeliveryTime Int      @default(30) // minutes
  createdAt             DateTime @default(now())

  vendor        Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  deliveryZones DeliveryZone[]
  menuItems     MenuItem[]
  orders        Order[]
  tables RestaurantTable[]

  @@index([vendorId])
}

model ManagerBranchMetrics {
  id          String   @id @default(uuid())
  managerId   String   @unique
  date        DateTime
  ordersCount Int      @default(0)
}

model DeliveryZone {
  id          String @id @default(uuid())
  branchId    String
  state       String
  lga         String
  area        String
  deliveryFee Float

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String
  price       Float
  images      String[] @default([])
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([branchId, createdAt, id])
}

model Order {
  id             String       @id @default(uuid())
  userId         String // Postgres User.id of buyer (FK -> User.id)
  userName       String @default("User") // snapshot at order time
  vendorId       String
  branchId       String
  subtotal       Float
  deliveryFee    Float
  transactionFee Float
  totalAmount    Float
  status         OrderStatus  @default(pending)
  escrowStatus   EscrowStatus @default(held)
  appealedBy     String? // userId of whoever filed the appeal

  // existing...
  paymentMethod String  @default("escrow") // "escrow" | "pay_on_delivery"
  podConfirmed  Boolean @default(false) // vendor confirms cash received

  // Delivery address (flat — no FK, structured data)
  deliveryState  String
  deliveryLga    String
  deliveryArea   String
  deliveryStreet String

  // Vendor snapshot (so vendor name still shows if vendor deletes account)
  vendorName  String @default("")
  vendorLogo  String @default("")
  vendorCover String @default("")
  branchName  String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor      @relation(fields: [vendorId], references: [id])
  branch Branch      @relation(fields: [branchId], references: [id])
  user   User        @relation(fields: [userId], references: [id])
  items  OrderItem[]
  fulfillmentType String  @default("delivery") // delivery | pickup | dine_in
  tableId         String?
  tableNumber     String?
  orderNumber     Int?
  escrow Escrow?

  @@index([createdAt])
  @@index([userId])
  @@index([status])
  @@index([branchId])

  @@index([userId, createdAt, id])
  @@index([branchId, createdAt, id])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  menuItemId String
  name       String // snapshot at order time
  price      Float // snapshot at order time — editing menu price won't affect this
  quantity   Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Escrow {
  id            String       @id @default(uuid())
  orderId       String       @unique
  amountHeld    Float
  commission    Float
  releaseStatus EscrowStatus @default(held)
  appealReason  String?
  autoReleaseAt DateTime
  releasedAt    DateTime?
  refundedAt    DateTime?
  createdAt     DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

enum SettlementHoldStatus {
  pending
  frozen
  released
  refunded
  cancelled
}

model MerchantBalance {
  id        String   @id @default(uuid())
  vendorId  String   @unique
  pending   Float    @default(0)
  available Float    @default(0)
  paidOut   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SettlementHold {
  id           String               @id @default(uuid())
  orderId      String               @unique
  vendorId     String
  gross        Float
  commission   Float                @default(0)
  net          Float
  status       SettlementHoldStatus @default(pending)
  settleAt     DateTime
  source       String               @default("wallet") // "wallet" | "opay"
  paymentId    String?
  frozenReason String?
  releasedAt   DateTime?
  refundedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([vendorId])
  @@index([status, settleAt])
  @@index([paymentId])
}

model Review {
  id        String   @id @default(uuid())
  vendorId  String
  orderId   String   @unique
  userId    String
  userName  String   @default("Customer")
  rating    Float // 1-5
  comment   String
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])
}

model AppConfig {
  id                    String @id @default("singleton") // always one row
  transactionFeePercent Float  @default(0) // 0 at launch — update here to change globally
  autoReleaseHours      Int    @default(24)
  appealWindowHours     Int    @default(48)
  chatCloseHours        Int    @default(72)
  commissionPercent     Float  @default(5)
  fundingFees           Float  @default(0)
  bonusAirtime          Float  @default(0)
  bonusData             Float  @default(0)
  bonusCable            Float  @default(0)
  bonusElectric         Float  @default(0)

  autoCancelMinutes Int @default(30)

  trustCatalog Json?   // admin override: { "3": { "benefits": [...], "tagline": "..." } }
}

model LocationState {
  id   String @id @default(uuid())
  name String @unique

  lgas LocationLga[]
}

model LocationLga {
  id      String @id @default(uuid())
  name    String
  stateId String

  state LocationState  @relation(fields: [stateId], references: [id])
  areas LocationArea[]
}

model LocationArea {
  id    String @id @default(uuid())
  name  String
  lgaId String

  lga     LocationLga      @relation(fields: [lgaId], references: [id])
  streets LocationStreet[]
}

model LocationStreet {
  id     String @id @default(uuid())
  name   String
  areaId String

  area LocationArea @relation(fields: [areaId], references: [id])
}

// schema.prisma - ADD THESE MODELS

// ── COIN SYSTEM ──────────────────────────────────────────────────────────────

model UserCoins {
  id           String   @id @default(uuid())
  userId       String   @unique
  balance      Int      @default(0) // Total coins available
  purchasedCoins Int     @default(0) // ADD — spend-only (IAP / NG wallet); NEVER converts
  earnedCoins    Int     @default(0) // ADD — received via gifts; ONLY these convert (NG-tied)
  totalEarned  Int      @default(0) // Lifetime coins earned (creators)
  totalSpent   Int      @default(0) // Lifetime coins spent (gifters)
  totalPurchased Int     @default(0) // ADD — lifetime purchased coins
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoinPurchase {
  id            String             @id @default(uuid())
  userId        String
  source        CoinPurchaseSource
  coins         Int
  amount        Float              @default(0) // NGN charged (wallet) | 0 for IAP (store holds cash)
  currency      String             @default("NGN")
  productId     String?            // store SKU / pack id
  platformToken String?            @unique     // Apple transaction_id | Google orderId | wallet clientRequestId — idempotency
  status        CoinPurchaseStatus @default(PENDING)
  verified      Boolean            @default(false)
  rawReceipt    Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user User @relation("CoinPurchases", fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([status])
}

model CoinBoost {
  id          String   @id @default(uuid())
  userId      String
  postId      String
  coinsSpent  Int
  durationHrs Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user User @relation("CoinBoosts", fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([postId])
}

model GiftTransaction {
  id              String   @id @default(uuid())
  senderId        String
  receiverId      String
  postId String?   // was: String  (now optional — user gifts have no post)
  // ...consider adding giftMessage or giftImageUrl for personalization?
  giftType        String   // "rose" | "coffee" | "fire" | "diamond" | "rocket" | "crown"
  coinAmount      Int      // Coins sent
  nairaEquivalent Float    // Money deducted (coinAmount / 10)
  platformFee     Float    // 5% of nairaEquivalent
  coinsAwarded    Int      // Coins creator receives (after fee)
  status          String   @default("completed")
  createdAt       DateTime @default(now())

  sender   User @relation("GiftSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("GiftReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([postId])
}

model CoinConversion {
  id            String   @id @default(uuid())
  userId        String
  coinAmount    Int      // Coins converted
  nairaAmount   Float    // Money credited to wallet
  conversionFee Float    @default(0) // Optional fee (0 for now)
  status        String   @default("completed")
  createdAt     DateTime @default(now())

  user User @relation("CoinConversions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CreatorStats {
  id                   String   @id @default(uuid())
  userId               String   @unique
  totalCoinsEarned     Int      @default(0)
  totalNairaEarned     Float    @default(0)
  totalGiftsReceived   Int      @default(0)
  weeklyCoins          Int      @default(0)
  weeklyResetAt        DateTime
  level                Int      @default(1)
  isKycVerified        Boolean  @default(false)
  lastUpdated          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserDailyLimit {
  id            String   @id @default(uuid())
  userId        String
  date          String   // YYYY-MM-DD format
  totalSpent    Float    @default(0)
  giftCount     Int      @default(0)
  lastGiftAt    DateTime
  createdAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// ── RECONCILIATION (mini-phase) ──────────────────────────────────────────────
// Append-only revenue ledger + daily float/coin solvency snapshots. All additive
// (new models + enums). Nothing references these from existing models, so the
// migration is safe to apply alongside the others.

enum RevenueSource {
  order_commission   // marketplace commission, realized at settlement
  pod_commission     // POD cash commission recovered via settlement offset
  transaction_fee    // AppConfig.transactionFeePercent (0 today)
  funding_fee        // AppConfig.fundingFees (0 today)
  utility_markup     // VTPass spread (0 today)
  gift_breakage      // 5% gift platform fee (coin rail)
  conversion_spread  // purchaseRate − conversionRate spread on cash-out (coin rail)
  coin_breakage      // unspent purchased coins recognized as revenue (future)
  manual_adjustment  // admin correction (may be negative)
}

enum RevenueTrack {
  ngn_float // realized as Naira inside the Paystack/OPay float
  coin      // realized inside the coin economy / IAP funding rail
}

enum ReconStatus {
  ok
  warn
  breach
}

model PlatformRevenue {
  id             String        @id @default(uuid())
  source         RevenueSource
  track          RevenueTrack  @default(ngn_float)
  amount         Float         // NGN value of the revenue event
  currency       String        @default("NGN")
  refType        String?       // "settlement_hold" | "gift" | "conversion" | ...
  refId          String?
  idempotencyKey String        @unique // e.g. "order_commission:<orderId>" — never double-books
  note           String?
  meta           Json?
  createdAt      DateTime      @default(now())

  @@index([source, createdAt])
  @@index([track, createdAt])
  @@index([createdAt])
}

model ReconciliationSnapshot {
  id        String   @id @default(uuid())
  takenAt   DateTime @default(now())
  takenBy   String?  // admin userId (manual) | null (nightly cron)

  // Track A — NGN wallet float (headline figures; full breakdown in `figures`)
  ngnLiabilities  Float       @default(0)
  ngnFloat        Float       @default(0)
  ngnSurplus      Float       @default(0)
  ngnStatus       ReconStatus @default(ok)

  // Track B — coin treasury
  coinLiability   Float       @default(0) // NG earned-coin cash-out obligation (₦)
  coinFunding     Float       @default(0)
  coinSurplus     Float       @default(0)
  coinStatus      ReconStatus @default(ok)

  // Float inputs (so a snapshot is reproducible / auditable)
  paystackBalance Float       @default(0)
  opayBalance     Float       @default(0)
  bankBalance     Float       @default(0) // operating/settlement bank (PSPs settle here)
  vtpassBalance   Float       @default(0) // VTPass prepaid wallet (backs utility delivery)
  appleBalance    Float       @default(0)
  googleBalance   Float       @default(0)
  paystackFetchOk Boolean     @default(false)

  figures Json?   // itemized breakdown of every line (see reconciliation.service)
  note    String?
  createdAt DateTime @default(now())

  @@index([takenAt])
}